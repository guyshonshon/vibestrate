{
  "schemaVersion": 1,
  "description": "Built-in run Flows. Project Flows live in `.vibestrate/flows/<id>/flow.yml` and follow the same schema (src/flows/schemas/flow-schema.ts).",
  "flows": [
    {
      "id": "default",
      "version": 1,
      "label": "Default",
      "description": "The standard plan → architect → implement → validate → review workflow. Review loops back to fix and re-validate until it passes or the bound is hit, then a verify gate decides merge-readiness. Runs when no other flow is picked.",
      "seats": [
        {
          "id": "planner",
          "label": "Planner",
          "description": "Turns the task into a plan."
        },
        {
          "id": "architect",
          "label": "Architect",
          "description": "Designs the approach from the plan."
        },
        {
          "id": "implementer",
          "label": "Implementer",
          "description": "Implements the plan and architecture."
        },
        {
          "id": "reviewer",
          "label": "Reviewer",
          "description": "Reviews the diff and decides whether changes are needed."
        },
        {
          "id": "fixer",
          "label": "Fixer",
          "description": "Addresses review findings."
        },
        {
          "id": "verifier",
          "label": "Verifier",
          "description": "Independently verifies the approved result."
        }
      ],
      "steps": [
        {
          "id": "plan",
          "label": "Plan",
          "kind": "agent-turn",
          "seat": "planner",
          "inputs": [
            "task-brief"
          ],
          "outputs": [
            "plan"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "continueOnError": false,
          "retries": 0,
          "stage": "planning",
          "approval": null,
          "repeat": null
        },
        {
          "id": "architecture",
          "label": "Architecture",
          "kind": "agent-turn",
          "seat": "architect",
          "inputs": [
            "task-brief",
            "plan"
          ],
          "outputs": [
            "architecture"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "continueOnError": false,
          "retries": 0,
          "stage": "architecting",
          "approval": null,
          "repeat": null
        },
        {
          "id": "implement",
          "label": "Implement",
          "kind": "agent-turn",
          "seat": "implementer",
          "inputs": [
            "task-brief",
            "plan",
            "architecture"
          ],
          "outputs": [
            "execution",
            "diff"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "continueOnError": false,
          "retries": 0,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "validation",
          "label": "Validate",
          "kind": "validation",
          "seat": null,
          "inputs": [
            "diff"
          ],
          "outputs": [
            "validation"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "continueOnError": false,
          "retries": 0,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "review",
          "label": "Review",
          "kind": "review-turn",
          "seat": "reviewer",
          "inputs": [
            "task-brief",
            "plan",
            "architecture",
            "execution",
            "validation"
          ],
          "outputs": [
            "findings",
            "review-decision"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "continueOnError": false,
          "retries": 0,
          "stage": "reviewing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "fix",
          "label": "Fix",
          "kind": "response-turn",
          "seat": "fixer",
          "inputs": [
            "task-brief",
            "plan",
            "architecture",
            "execution",
            "findings",
            "validation"
          ],
          "outputs": [
            "finding-responses",
            "diff"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "continueOnError": false,
          "retries": 0,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "revalidation",
          "label": "Re-validate",
          "kind": "validation",
          "seat": null,
          "inputs": [
            "diff"
          ],
          "outputs": [
            "validation"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "continueOnError": false,
          "retries": 0,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "verify",
          "label": "Verify",
          "kind": "summary-turn",
          "seat": "verifier",
          "inputs": [
            "task-brief",
            "plan",
            "architecture",
            "execution",
            "findings",
            "validation"
          ],
          "outputs": [
            "verification"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "continueOnError": false,
          "retries": 0,
          "stage": "verifying",
          "approval": null,
          "repeat": null
        }
      ],
      "loop": {
        "from": "review",
        "to": "revalidation",
        "decisionStep": "review",
        "maxIterations": 3
      }
    },
    {
      "id": "quality-arbitration",
