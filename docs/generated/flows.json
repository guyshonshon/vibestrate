{
  "schemaVersion": 1,
  "description": "Built-in run Flows. Project Flows live in `.vibestrate/flows/<id>/flow.yml` and follow the same schema (src/flows/schemas/flow-schema.ts).",
  "flows": [
    {
      "id": "default",
      "version": 1,
      "label": "Default",
      "description": "The standard plan → architect → implement → validate → review workflow. Review loops back to fix and re-validate until it passes or the bound is hit, then a verify gate decides merge-readiness. Runs when no other flow is picked.",
      "seats": [
        {
          "id": "planner",
          "label": "Planner",
          "description": "Turns the task into a plan."
        },
        {
          "id": "architect",
          "label": "Architect",
          "description": "Designs the approach from the plan."
        },
        {
          "id": "implementer",
          "label": "Implementer",
          "description": "Implements the plan and architecture."
        },
        {
          "id": "reviewer",
          "label": "Reviewer",
          "description": "Reviews the diff and decides whether changes are needed."
        },
        {
          "id": "fixer",
          "label": "Fixer",
          "description": "Addresses review findings."
        },
        {
          "id": "verifier",
          "label": "Verifier",
          "description": "Independently verifies the approved result."
        }
      ],
      "steps": [
        {
          "id": "plan",
          "label": "Plan",
          "kind": "agent-turn",
          "seat": "planner",
          "inputs": [
            "task-brief"
          ],
          "outputs": [
            "plan"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": "planning",
          "approval": null,
          "repeat": null
        },
        {
          "id": "architecture",
          "label": "Architecture",
          "kind": "agent-turn",
          "seat": "architect",
          "inputs": [
            "task-brief",
            "plan"
          ],
          "outputs": [
            "architecture"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": "architecting",
          "approval": null,
          "repeat": null
        },
        {
          "id": "implement",
          "label": "Implement",
          "kind": "agent-turn",
          "seat": "implementer",
          "inputs": [
            "task-brief",
            "plan",
            "architecture"
          ],
          "outputs": [
            "execution",
            "diff"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "validation",
          "label": "Validate",
          "kind": "validation",
          "seat": null,
          "inputs": [
            "diff"
          ],
          "outputs": [
            "validation"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "review",
          "label": "Review",
          "kind": "review-turn",
          "seat": "reviewer",
          "inputs": [
            "task-brief",
            "plan",
            "architecture",
            "execution",
            "validation"
          ],
          "outputs": [
            "findings",
            "review-decision"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": "reviewing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "fix",
          "label": "Fix",
          "kind": "response-turn",
          "seat": "fixer",
          "inputs": [
            "task-brief",
            "plan",
            "architecture",
            "execution",
            "findings",
            "validation"
          ],
          "outputs": [
            "finding-responses",
            "diff"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "revalidation",
          "label": "Re-validate",
          "kind": "validation",
          "seat": null,
          "inputs": [
            "diff"
          ],
          "outputs": [
            "validation"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "stage": "executing",
          "approval": null,
          "repeat": null
        },
        {
          "id": "verify",
          "label": "Verify",
          "kind": "summary-turn",
          "seat": "verifier",
          "inputs": [
            "task-brief",
            "plan",
            "architecture",
            "execution",
            "findings",
            "validation"
          ],
          "outputs": [
            "verification"
          ],
          "optional": false,
          "skipWhenReadOnly": true,
          "stage": "verifying",
          "approval": null,
          "repeat": null
        }
      ],
      "loop": {
        "from": "review",
        "to": "revalidation",
        "decisionStep": "review",
        "maxIterations": 3
      }
    },
    {
      "id": "quality-arbitration",
      "version": 1,
      "label": "Quality Arbitration",
      "description": "Cross-provider planning, review, implementation, challenge, second review, and Vibestrate decision summary.",
      "seats": [
        {
          "id": "builder",
          "label": "Builder",
          "description": "Plans, implements, and answers review findings."
        },
        {
          "id": "challenger",
          "label": "Challenger",
          "description": "Challenges plans and code before the final decision."
        },
        {
          "id": "arbiter",
          "label": "Arbiter",
          "description": "Summarizes evidence, disagreement, and residual risk."
        }
      ],
      "steps": [
        {
          "id": "plan",
          "label": "Plan",
          "kind": "agent-turn",
          "seat": "builder",
          "inputs": [
            "task-brief"
          ],
          "outputs": [
            "plan"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        },
        {
          "id": "plan-review",
          "label": "Plan Review",
          "kind": "review-turn",
          "seat": "challenger",
          "inputs": [
            "task-brief",
            "plan"
          ],
          "outputs": [
            "findings"
          ],
          "optional": true,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        },
        {
          "id": "implement",
          "label": "Implement",
          "kind": "agent-turn",
          "seat": "builder",
          "inputs": [
            "task-brief",
            "plan",
            "findings"
          ],
          "outputs": [
            "execution",
            "diff"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        },
        {
          "id": "validation",
          "label": "Validate",
          "kind": "validation",
          "seat": null,
          "inputs": [
            "diff"
          ],
          "outputs": [
            "validation"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        },
        {
          "id": "implementation-review",
          "label": "Implementation Review",
          "kind": "review-turn",
          "seat": "challenger",
          "inputs": [
            "plan",
            "diff",
            "validation"
          ],
          "outputs": [
            "findings",
            "review-decision"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        },
        {
          "id": "challenge-response",
          "label": "Challenge Response",
          "kind": "response-turn",
          "seat": "builder",
          "inputs": [
            "findings",
            "diff",
            "validation"
          ],
          "outputs": [
            "finding-responses",
            "diff"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        },
        {
          "id": "second-review",
          "label": "Second Review",
          "kind": "review-turn",
          "seat": "challenger",
          "inputs": [
            "findings",
            "finding-responses",
            "diff",
            "validation"
          ],
          "outputs": [
            "finding-resolutions",
            "review-decision"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        },
        {
          "id": "decision-summary",
          "label": "Decision Summary",
          "kind": "summary-turn",
          "seat": "arbiter",
          "inputs": [
            "plan",
            "findings",
            "finding-responses",
            "finding-resolutions",
            "diff",
            "validation"
          ],
          "outputs": [
            "decision-summary"
          ],
          "optional": false,
          "skipWhenReadOnly": false,
          "stage": null,
          "approval": null,
          "repeat": null
        }
      ],
      "loop": null
    }
  ]
}
