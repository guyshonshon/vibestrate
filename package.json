{
  "name": "amaco-os",
  "version": "0.1.1",
  "description": "Amaco — local-first autonomous multi-agent completion orchestrator for software tasks. Runs your existing local agent CLIs through a controlled plan → architect → implement → validate → review → fix → verify loop in isolated git worktrees.",
  "license": "Apache-2.0",
  "author": "Guy Shonshon (https://shonshon.com)",
  "homepage": "https://amaco.shonshon.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyshonshon/amaco.git"
  },
  "bugs": {
    "url": "https://github.com/guyshonshon/amaco/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "amaco": "dist/index.js"
  },
  "files": [
    "dist",
    "src/agents/default-prompts",
    "src/ui/lib/types.ts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "dev:ui": "vite",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && pnpm build:cli && pnpm build:ui",
    "build:cli": "tsup",
    "build:ui": "vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "docs:generate": "tsx scripts/generate-docs-metadata.ts",
    "release": "bash scripts/release.sh",
    "update-deps": "bash scripts/update-deps.sh",
    "prepublishOnly": "pnpm build && node scripts/prepublish-trim.mjs"
  },
  "dependencies": {
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@inquirer/prompts": "^8.4.2",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fastify": "^5.8.5",
    "highlight.js": "^11.11.1",
    "ink": "^7.0.3",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.6",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "lucide-react": "^1.14.0",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.11",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "agent",
    "orchestrator",
    "claude-code",
    "codex",
    "aider",
    "opencode",
    "multi-agent",
    "autonomous",
    "git-worktree",
    "local-first"
  ],
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.20.1": ">=8.20.1"
    }
  }
}
