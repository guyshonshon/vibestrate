{
  "name": "amaco",
  "version": "0.0.1",
  "description": "Amaco — local-first autonomous multi-agent completion orchestrator for software tasks. Runs your existing local agent CLIs through a controlled plan → architect → implement → validate → review → fix → verify loop in isolated git worktrees.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "amaco": "./dist/index.js"
  },
  "files": [
    "dist",
    "src/agents/default-prompts",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "build": "tsup src/cli/index.ts --format esm --dts --clean",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "keywords": [
    "agent",
    "orchestrator",
    "claude-code",
    "codex",
    "aider",
    "opencode",
    "multi-agent",
    "autonomous",
    "git-worktree",
    "local-first"
  ]
}
