{
  "name": "vibestrate",
  "version": "0.71.1",
  "description": "Vibestrate is an open-source AI CTO for supervised coding flows: swap Claude Code, Codex, Gemini, or local models across shared crews with approval gates and local run logs.",
  "license": "Apache-2.0",
  "author": "Guy Shonshon (https://shonshon.com)",
  "homepage": "https://vibestrate.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/guyshonshon/vibestrate.git"
  },
  "bugs": {
    "url": "https://github.com/guyshonshon/vibestrate/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "vibe": "dist/index.js",
    "vibestrate": "dist/index.js"
  },
  "files": [
    "dist",
    "src/roles/default-prompts",
    "src/ui/lib/types.ts",
    "README.md",
    ".github/SECURITY.md",
    "LICENSE",
    "NOTICE",
    "docs/content"
  ],
  "engines": {
    "node": ">=18.17"
  },
  "packageManager": "pnpm@10.26.0",
  "scripts": {
    "dev": "tsx src/cli/index.ts",
    "dev:ui": "vite",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && pnpm build:cli && pnpm build:ui",
    "build:cli": "tsup",
    "build:ui": "vite build",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit && tsc -p tsconfig.ui.json --noEmit",
    "docs:generate": "tsx scripts/generate-docs-metadata.ts",
    "demo": "tsx scripts/demo-simulation.ts",
    "release": "bash scripts/release.sh",
    "update-deps": "bash scripts/update-deps.sh",
    "prepublishOnly": "pnpm build && node scripts/prepublish-trim.mjs"
  },
  "dependencies": {
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "6.12.3",
    "@fastify/static": "^9.1.3",
    "@fastify/websocket": "^11.2.0",
    "@fontsource-variable/bricolage-grotesque": "^5.2.10",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/plus-jakarta-sans": "^5.2.8",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@inquirer/core": "^11.1.9",
    "@inquirer/prompts": "^8.4.2",
    "@lezer/highlight": "1.2.3",
    "@radix-ui/react-label": "^2.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@uiw/react-codemirror": "^4.25.10",
    "@visx/axis": "^4.0.0",
    "@visx/curve": "^4.0.0",
    "@visx/event": "^4.0.0",
    "@visx/gradient": "^4.0.0",
    "@visx/grid": "^4.0.0",
    "@visx/group": "^4.0.0",
    "@visx/heatmap": "^4.0.0",
    "@visx/responsive": "^4.0.0",
    "@visx/scale": "^4.0.0",
    "@visx/shape": "^4.0.0",
    "@visx/tooltip": "^4.0.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.1.0",
    "execa": "^9.5.1",
    "fastify": "^5.8.5",
    "highlight.js": "^11.11.1",
    "ink": "^7.0.3",
    "ink-select-input": "^6.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^6.0.0",
    "react": "^19.2.6",
    "react-grid-layout": "2.2.3",
    "tailwind-merge": "^3.6.0",
    "yaml": "^2.6.1",
    "zod": "^3.23.8"
  },
  "optionalDependencies": {
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "ink-testing-library": "^4.0.0",
    "lucide-react": "^1.14.0",
    "react-dom": "^19.2.6",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "ai-cto",
    "supervised-ai",
    "model-independence",
    "agent-orchestration",
    "shared-flows",
    "claude-code",
    "codex",
    "gemini",
    "aider",
    "opencode",
    "multi-agent",
    "orchestrator",
    "git-worktree",
    "local-first"
  ],
  "pnpm": {
    "overrides": {
      "ws@>=8.0.0 <8.20.1": ">=8.20.1",
      "esbuild@>=0.17.0 <0.28.1": ">=0.28.1"
    }
  }
}
